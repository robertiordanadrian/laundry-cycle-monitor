{
  "name": "laundry-cycle-monitor",
  "version": "1.0.0",
  "description": "Laundry Cycle Monitor — plan and pay for washing and drying cycles.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.2.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k -n BE,FE -c yellow,cyan \"npm:start:api\" \"npm:start:web\"",
    "start:web": "ng serve --proxy-config proxy.conf.json --open",
    "start:api": "json-server backend-api.json --watch --port 3000 --delay 250 --no-cors=false",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "lint": "ng lint && stylelint \"src/**/*.scss\"",
    "lint:fix": "ng lint --fix && stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@angular/animations": "^19.1.0",
    "@angular/cdk": "^19.1.0",
    "@angular/common": "^19.1.0",
    "@angular/compiler": "^19.1.0",
    "@angular/core": "^19.1.0",
    "@angular/forms": "^19.1.0",
    "@angular/material": "^19.1.0",
    "@angular/platform-browser": "^19.1.0",
    "@angular/platform-browser-dynamic": "^19.1.0",
    "@angular/router": "^19.1.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.0",
    "@angular/cli": "^19.1.0",
    "@angular/compiler-cli": "^19.1.0",
    "@eslint/js": "^9.17.0",
    "@types/jasmine": "~5.1.5",
    "angular-eslint": "^19.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.5.0",
    "json-server": "^0.17.4",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^15.3.0",
    "postcss": "^8.4.49",
    "postcss-html": "^1.7.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
